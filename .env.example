# Copy to .env (same directory) and fill in your real key.
# .env is git-ignored so the real key never gets committed.
#
# In the Udacity / Vocareum workspace the key is the voc-... value the course
# provided. Locally you can use a normal sk-... OpenAI key, in which case
# also set OPENAI_API_BASE=https://api.openai.com/v1 below.
OPENAI_API_KEY=sk-...
OPENAI_API_BASE=https://openai.vocareum.com/v1
